# =============================================
# NEXTSTEP — Environment Variables
# =============================================
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub

# Flask
SECRET_KEY=change-this-to-a-long-random-string-before-going-live
FLASK_ENV=production

# Database (Render PostgreSQL — paste your Internal Database URL from Render dashboard)
DATABASE_URL=postgresql://user:password@host:5432/nextstep_db

# Email (Gmail App Password — fill in when domain email is ready)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=raj.nextstepoutsourcing@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here
MAIL_DEFAULT_SENDER=raj.nextstepoutsourcing@gmail.com

# Owner seed (used only on first run to create owner account)
OWNER_EMAIL=raj.nextstepoutsourcing@gmail.com
OWNER_PASSWORD=Nextstep@2026
OWNER_NAME=Raj
